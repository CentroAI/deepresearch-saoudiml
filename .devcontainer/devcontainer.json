{
  "name": "Deep Research From Scratch",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bullseye",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "onCreateCommand": "bash .devcontainer/setup.sh",
  "updateContentCommand": "bash .devcontainer/setup.sh",

  "containerEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}"
  },

  "remoteEnv": {
    "LANGCHAIN_TRACING_V2": "true",
    "LANGCHAIN_PROJECT": "deep-research-course",
    "VIRTUAL_ENV": "${workspaceFolder}/.venv",
    "PATH": "${workspaceFolder}/.venv/bin:${containerEnv:PATH}"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.terminal.activateEnvironment": true,
        "jupyter.defaultKernel": "deep-research",
        "jupyter.notebookFileRoot": "${workspaceFolder}/notebooks",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        },
        "files.exclude": {
          "**/.env": true,
          "**/__pycache__": true,
          "**/*.egg-info": true
        }
      }
    }
  }
}
